# Server
PORT=3001
NODE_ENV=development

# Authentication (set to enable write-protected mode)
# When set, POST/PUT/PATCH/DELETE to /api/models and /api/settings require
# the x-api-key header (or Authorization: Bearer <key>) to match this value.
# Leave unset to run without auth (local/personal use only).
API_KEY=

# OpenRouter — default API key for prompt testing (optional)
# Users can also bring their own key via x-openrouter-key header.
OPENROUTER_API_KEY=

# CORS — comma-separated allowed origins
# In production, set to your frontend domain(s), e.g. https://myapp.com
# In development, defaults to http://localhost:3001, http://localhost:5173
# If empty in production, CORS reverts to open (not recommended).
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
